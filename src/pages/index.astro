---
export const prerender = true;

import towns from "../data/towns/ma-towns.json";
import services from "../data/services/ma-services.json";
import companies from "../data/companies/ma-companies.json";

const norm = (v) => String(v ?? "").trim().toLowerCase();

// Build lookups from companies
const townsWithProvidersSet = new Set();
const servicesByTown = new Map();

for (const c of companies) {
  const t = norm(c?.townSlug);
  const s = norm(c?.serviceId);
  if (!t || !s) continue;

  townsWithProvidersSet.add(t);

  if (!servicesByTown.has(t)) servicesByTown.set(t, new Set());
  servicesByTown.get(t).add(s);
}

const townsWithProviders = towns
  .filter((t) => townsWithProvidersSet.has(norm(t?.slug)))
  .slice()
  .sort((a, b) => String(a.name).localeCompare(String(b.name)));

const serviceCatalog = services
  .slice()
  .map((s) => ({ id: String(s.id), name: String(s.name) }))
  .sort((a, b) => a.name.localeCompare(b.name));

const servicesUsedSet = new Set();
for (const [, set] of servicesByTown.entries()) {
  for (const sid of set) servicesUsedSet.add(sid);
}

const servicesInitial = serviceCatalog.filter((s) => servicesUsedSet.has(norm(s.id)));

const servicesByTownObj = {};
for (const [townSlug, set] of servicesByTown.entries()) {
  servicesByTownObj[townSlug] = Array.from(set);
}

const townsWithProvidersClient = townsWithProviders.map((t) => ({
  slug: String(t.slug),
  name: String(t.name),
}));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ProNest New England</title>
    <meta
      name="description"
      content="ProNest New England connects homeowners and businesses with reliable local service providers across Massachusetts."
    />

    <meta name="build-check" content="INDEX_SEARCHABLE_TOWN_V5_MOBILE_DROPDOWN_SCROLL_FIX" />

    <style>
      :root { font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; }
      body { margin: 0; background: #fff; color: #111; }

      .site-header {
        border-bottom: 1px solid #e5e7eb;
        background: #ffffff;
      }

      .header-inner {
        max-width: 1100px;
        margin: 0 auto;
        padding: 14px 16px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
      }

      .brand-link {
        display: inline-flex;
        align-items: center;
        text-decoration: none;
      }

      .brand-link img {
        display: block;
        height: 72px;
        width: auto;
      }

      .nav {
        display: flex;
        align-items: center;
        gap: 18px;
        flex-wrap: wrap;
      }

      .nav a {
        text-decoration: none;
        color: #111827;
        font-size: 15px;
        font-weight: 600;
      }

      .nav a:hover {
        text-decoration: underline;
      }

      .wrap {
        max-width: 980px;
        margin: 0 auto;
        padding: 42px 16px 72px;
      }

      .hero {
        display: grid;
        gap: 24px;
      }

      .eyebrow {
        margin: 0;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #2563eb;
      }

      h1 {
        margin: 0;
        font-size: 36px;
        line-height: 1.1;
        letter-spacing: -0.02em;
      }

      .subtext {
        margin: 0;
        font-size: 17px;
        color: #374151;
        line-height: 1.6;
        max-width: 760px;
      }

      .search-card {
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        padding: 28px 26px;
        background: #f8fafc;
        box-shadow: 0 12px 28px rgba(0, 0, 0, 0.05);
      }

      .search-card h2 {
        margin: 0 0 8px 0;
        font-size: 24px;
        line-height: 1.2;
      }

      .search-card p {
        margin: 0 0 18px 0;
        font-size: 15px;
        color: #4b5563;
      }

      .grid {
        display: grid;
        grid-template-columns: 1fr 1fr auto;
        gap: 14px;
        align-items: start;
      }

      .grid > div {
        min-width: 0;
      }

      label {
        display: block;
        font-size: 13px;
        margin-bottom: 6px;
        color: #111827;
        font-weight: 600;
      }

      select,
      .town-input {
        width: 100%;
        height: 56px;
        padding: 0 16px;
        border-radius: 14px;
        border: 1px solid #d1d5db;
        background: #fff;
        font-size: 15px;
        box-sizing: border-box;
      }

      .town-search-wrap {
        position: relative;
      }

      .town-input:focus,
      select:focus {
        outline: 3px solid rgba(37, 99, 235, 0.15);
        outline-offset: 1px;
        border-color: #93c5fd;
      }

      .town-results {
        position: absolute;
        top: calc(100% + 6px);
        left: 0;
        right: 0;
        z-index: 30;
        background: #ffffff;
        border: 1px solid #dbe3ee;
        border-radius: 14px;
        box-shadow: 0 14px 30px rgba(15, 23, 42, 0.12);
        overflow: hidden;
        max-height: min(260px, 40vh);
        overscroll-behavior: contain;
        -webkit-overflow-scrolling: touch;
      }

      .town-results[hidden] {
        display: none;
      }

      .town-results-list {
        margin: 0;
        padding: 6px 0;
        list-style: none;
        max-height: min(260px, 40vh);
        overflow-y: auto;
        overscroll-behavior: contain;
        -webkit-overflow-scrolling: touch;
      }

      .town-results-list li {
        margin: 0;
        padding: 0;
      }

      .town-result-btn {
        appearance: none;
        -webkit-appearance: none;
        display: block;
        width: 100%;
        margin: 0;
        padding: 11px 14px;
        border: 0;
        border-radius: 0;
        background: transparent;
        box-shadow: none;
        color: #111827;
        text-align: left;
        font-size: 15px;
        font-weight: 500;
        line-height: 1.35;
        cursor: pointer;
        transition: background-color 0.14s ease;
      }

      .town-result-btn:hover,
      .town-result-btn:focus-visible,
      .town-result-btn.active {
        background: #eff6ff;
        color: #111827;
        outline: none;
        transform: none;
      }

      .town-results-list li + li .town-result-btn {
        border-top: 1px solid #f1f5f9;
      }

      .town-empty {
        padding: 12px 14px;
        font-size: 14px;
        color: #6b7280;
      }

      .town-helper {
        margin-top: 6px;
        font-size: 12px;
        color: #6b7280;
      }

      .search-action {
        display: flex;
        align-items: flex-start;
        padding-top: 29px;
      }

      button {
        height: 56px;
        padding: 0 26px;
        border-radius: 14px;
        border: 1px solid #15803d;
        background: #16a34a;
        color: #fff;
        cursor: pointer;
        font-size: 15px;
        font-weight: 700;
        white-space: nowrap;
        box-shadow: 0 6px 16px rgba(22, 163, 74, 0.22);
        transition: all 0.2s ease;
      }

      button:focus-visible {
        outline: 3px solid rgba(34, 197, 94, 0.28);
        outline-offset: 2px;
      }

      .error {
        margin-top: 10px;
        font-size: 13px;
        color: #b00020;
        display: none;
      }

      .browse-row {
        margin-top: 22px;
      }

      .browse-link {
        display: inline-block;
        font-size: 16px;
        font-weight: 600;
        color: #111827;
        text-decoration: underline;
      }

      .info-card {
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        padding: 24px 22px;
        background: #ffffff;
        margin-top: 6px;
      }

      .info-card h3 {
        margin: 0 0 10px 0;
        font-size: 20px;
      }

      .info-card p {
        margin: 0;
        font-size: 15px;
        color: #374151;
        line-height: 1.6;
      }

      @media (hover: hover) and (pointer: fine) {
        button:hover {
          background: #15803d;
          border-color: #166534;
          transform: translateY(-1px);
          box-shadow: 0 10px 22px rgba(21, 128, 61, 0.28);
        }

        .town-result-btn:hover {
          background: #eff6ff;
          border-color: transparent;
          transform: none;
          box-shadow: none;
        }
      }

      @media (max-width: 760px) {
        .header-inner {
          flex-direction: column;
          align-items: center;
          text-align: center;
        }

        .brand-link img {
          height: 60px;
        }

        .nav {
          width: 100%;
          gap: 14px;
          justify-content: center;
        }

        .wrap {
          padding: 30px 16px 56px;
        }

        h1 {
          font-size: 30px;
        }

        .grid {
          grid-template-columns: 1fr;
        }

        .search-action {
          width: 100%;
          padding-top: 0;
        }

        button {
          width: 100%;
        }

        .search-card {
          padding: 20px 18px;
        }

        .town-results {
          max-height: min(240px, 32vh);
        }

        .town-results-list {
          max-height: min(240px, 32vh);
        }
      }

      @media (max-width: 520px) {
        .town-results {
          max-height: min(200px, 28vh);
        }

        .town-results-list {
          max-height: min(200px, 28vh);
        }

        .town-result-btn {
          padding: 12px 14px;
          font-size: 16px;
        }
      }
    </style>
  </head>

  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="brand-link" aria-label="ProNest New England home">
          <img src="/logo.png" alt="ProNest New England logo" />
        </a>

        <nav class="nav" aria-label="Main navigation">
          <a href="/">Home</a>
          <a href="/ma/">Massachusetts</a>
          <a href="/claim/">Claim Listing</a>
        </nav>
      </div>
    </header>

    <main class="wrap">
      <section class="hero">
        <p class="eyebrow">Massachusetts Service Directory</p>

        <h1>No Forms. No Spam. Just Local Pros.</h1>

        <p class="subtext">
          Search by town and service to find trusted local providers fast. Call or visit their website directly—we don’t get in the way.
        </p>

        <div class="search-card">
          <h2>Search the directory</h2>
          <p>Choose a town and service to go directly to available providers.</p>

          <div class="grid">
            <div>
              <label for="townSearch">Town</label>
              <div class="town-search-wrap">
                <input
                  id="townSearch"
                  class="town-input"
                  type="text"
                  inputmode="text"
                  autocomplete="off"
                  spellcheck="false"
                  placeholder="Search for a town"
                  aria-autocomplete="list"
                  aria-expanded="false"
                  aria-controls="townResults"
                />
                <input id="townSlug" type="hidden" value="" />
                <div id="townResults" class="town-results" hidden></div>
              </div>
              <div class="town-helper">Start typing to find a town faster.</div>
            </div>

            <div>
              <label for="serviceSelect">Service</label>
              <select id="serviceSelect">
                <option value="">Select a service</option>
                {servicesInitial.map((s) => (
                  <option value={s.id}>{s.name}</option>
                ))}
              </select>
            </div>

            <div class="search-action">
              <button id="searchBtn" type="button">Search</button>
            </div>
          </div>

          <div id="errorMsg" class="error"></div>

          <div class="browse-row">
            <a class="browse-link" href="/ma/">Browse Massachusetts Directory</a>
          </div>
        </div>

        <div class="info-card">
          <h3>Find trusted local professionals</h3>
          <p>
            ProNest New England connects homeowners and businesses with trusted service providers across Massachusetts.
          </p>
        </div>
      </section>
    </main>

    <script
      type="application/json"
      id="__servicesByTown"
      set:html={JSON.stringify(servicesByTownObj)}
    ></script>

    <script
      type="application/json"
      id="__serviceCatalog"
      set:html={JSON.stringify(serviceCatalog)}
    ></script>

    <script
      type="application/json"
      id="__townCatalog"
      set:html={JSON.stringify(townsWithProvidersClient)}
    ></script>

    <script is:inline>
      (function () {
        function norm(v) { return String(v || "").trim().toLowerCase(); }

        var townSearch = document.getElementById("townSearch");
        var townSlugInput = document.getElementById("townSlug");
        var townResults = document.getElementById("townResults");
        var serviceSelect = document.getElementById("serviceSelect");
        var searchBtn = document.getElementById("searchBtn");
        var errorMsg = document.getElementById("errorMsg");

        function showError(msg) {
          if (!errorMsg) return;
          if (!msg) {
            errorMsg.style.display = "none";
            errorMsg.textContent = "";
            return;
          }
          errorMsg.textContent = msg;
          errorMsg.style.display = "block";
        }

        function readJson(id) {
          var el = document.getElementById(id);
          if (!el) return null;
          try { return JSON.parse(el.textContent); } catch (e) { return null; }
        }

        var servicesByTown = readJson("__servicesByTown") || {};
        var catalog = readJson("__serviceCatalog") || [];
        var townCatalog = readJson("__townCatalog") || [];

        var activeTownIndex = -1;
        var currentTownMatches = [];

        function rebuildServiceOptions(list) {
          var keepValue = serviceSelect.value;

          serviceSelect.innerHTML = "";
          var ph = document.createElement("option");
          ph.value = "";
          ph.textContent = "Select a service";
          serviceSelect.appendChild(ph);

          if (!list || list.length === 0) {
            var none = document.createElement("option");
            none.value = "";
            none.textContent = "No services available";
            serviceSelect.appendChild(none);
            serviceSelect.value = "";
            return;
          }

          for (var i = 0; i < list.length; i++) {
            var s = list[i];
            var opt = document.createElement("option");
            opt.value = s.id;
            opt.textContent = s.name;
            serviceSelect.appendChild(opt);
          }

          var stillValid = list.some(function (s) { return s.id === keepValue; });
          serviceSelect.value = stillValid ? keepValue : "";
        }

        function servicesForTown(townSlug) {
          var t = norm(townSlug);
          if (!t) {
            var used = new Set();
            Object.keys(servicesByTown).forEach(function (k) {
              (servicesByTown[k] || []).forEach(function (sid) { used.add(norm(sid)); });
            });
            return catalog.filter(function (s) { return used.has(norm(s.id)); });
          }

          var allowed = new Set((servicesByTown[t] || []).map(norm));
          return catalog.filter(function (s) { return allowed.has(norm(s.id)); });
        }

        function closeTownResults() {
          activeTownIndex = -1;
          currentTownMatches = [];
          townResults.hidden = true;
          townSearch.setAttribute("aria-expanded", "false");
          townResults.innerHTML = "";
        }

        function selectTown(town) {
          townSearch.value = town.name;
          townSlugInput.value = town.slug;
          rebuildServiceOptions(servicesForTown(town.slug));
          closeTownResults();
        }

        function renderTownResults(matches) {
          currentTownMatches = matches.slice();
          activeTownIndex = -1;
          townResults.innerHTML = "";

          if (!matches.length) {
            var empty = document.createElement("div");
            empty.className = "town-empty";
            empty.textContent = "No matching towns found.";
            townResults.appendChild(empty);
            townResults.hidden = false;
            townSearch.setAttribute("aria-expanded", "true");
            return;
          }

          var list = document.createElement("ul");
          list.className = "town-results-list";

          for (var i = 0; i < matches.length; i++) {
            (function (town, index) {
              var item = document.createElement("li");

              var btn = document.createElement("button");
              btn.type = "button";
              btn.className = "town-result-btn";
              btn.textContent = town.name;
              btn.setAttribute("data-index", String(index));

              btn.addEventListener("mousedown", function (e) {
                e.preventDefault();
              });

              btn.addEventListener("click", function () {
                selectTown(town);
              });

              item.appendChild(btn);
              list.appendChild(item);
            })(matches[i], i);
          }

          townResults.appendChild(list);
          townResults.hidden = false;
          townSearch.setAttribute("aria-expanded", "true");
        }

        function updateActiveTownResult() {
          var buttons = townResults.querySelectorAll(".town-result-btn");
          for (var i = 0; i < buttons.length; i++) {
            if (i === activeTownIndex) {
              buttons[i].classList.add("active");
              if (typeof buttons[i].scrollIntoView === "function") {
                buttons[i].scrollIntoView({ block: "nearest" });
              }
            } else {
              buttons[i].classList.remove("active");
            }
          }
        }

        function filterTowns(query) {
          var q = norm(query);

          if (!q) {
            return townCatalog.slice(0, 12);
          }

          var startsWith = [];
          var contains = [];

          for (var i = 0; i < townCatalog.length; i++) {
            var town = townCatalog[i];
            var townName = norm(town.name);

            if (townName.indexOf(q) === 0) {
              startsWith.push(town);
            } else if (townName.indexOf(q) !== -1) {
              contains.push(town);
            }
          }

          return startsWith.concat(contains).slice(0, 12);
        }

        if (!townSearch || !townSlugInput || !townResults || !serviceSelect || !searchBtn) return;

        townSearch.addEventListener("focus", function () {
          renderTownResults(filterTowns(townSearch.value));
        });

        townSearch.addEventListener("input", function () {
          showError("");
          townSlugInput.value = "";
          rebuildServiceOptions(servicesForTown(""));
          renderTownResults(filterTowns(townSearch.value));
        });

        townSearch.addEventListener("keydown", function (e) {
          if (townResults.hidden || !currentTownMatches.length) {
            if (e.key === "ArrowDown") {
              renderTownResults(filterTowns(townSearch.value));
              e.preventDefault();
            }
            return;
          }

          if (e.key === "ArrowDown") {
            activeTownIndex = Math.min(activeTownIndex + 1, currentTownMatches.length - 1);
            updateActiveTownResult();
            e.preventDefault();
            return;
          }

          if (e.key === "ArrowUp") {
            if (activeTownIndex <= 0) {
              activeTownIndex = 0;
            } else {
              activeTownIndex = activeTownIndex - 1;
            }
            updateActiveTownResult();
            e.preventDefault();
            return;
          }

          if (e.key === "Enter") {
            if (activeTownIndex >= 0 && currentTownMatches[activeTownIndex]) {
              e.preventDefault();
              selectTown(currentTownMatches[activeTownIndex]);
            }
            return;
          }

          if (e.key === "Escape") {
            closeTownResults();
          }
        });

        townSearch.addEventListener("blur", function () {
          window.setTimeout(function () {
            if (!townSlugInput.value) {
              var typed = norm(townSearch.value);
              var exact = townCatalog.find(function (t) { return norm(t.name) === typed; });
              if (exact) {
                selectTown(exact);
                return;
              }
            }
            closeTownResults();
          }, 120);
        });

        serviceSelect.addEventListener("change", function () {
          showError("");
        });

        searchBtn.addEventListener("click", function () {
          showError("");

          var town = norm(townSlugInput.value);
          var service = norm(serviceSelect.value);

          if (!townSearch.value.trim()) {
            showError("Search for and select a town first.");
            return;
          }

          if (!town) {
            var typed = norm(townSearch.value);
            var exact = townCatalog.find(function (t) { return norm(t.name) === typed; });
            if (exact) {
              selectTown(exact);
              town = norm(exact.slug);
            }
          }

          if (!town && service) {
            showError("Select a valid town first (service-only search is not supported).");
            return;
          }

          if (!town) {
            showError("Select a valid town from the search list.");
            return;
          }

          var path = "/ma/" + town + "/";
          if (service) path = "/ma/" + town + "/" + service + "/";

          window.location.href = path;
        });
      })();
    </script>
  </body>
</html>