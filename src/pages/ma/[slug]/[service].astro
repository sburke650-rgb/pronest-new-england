export function getStaticPaths() {
  const paths = [];

  for (const town of towns) {
    for (const service of services) {
      if (!town?.slug || !service?.id) continue;

      paths.push({
        params: {
          slug: String(town.slug),
          service: String(service.id),
        },
      });
    }
  }

  return paths;
}

const { slug, service } = Astro.params;

const townSlug = norm(slug);
const serviceId = norm(service);

const town = towns.find((t) => norm(t.slug) === townSlug) ?? null;
const serviceObj = services.find((s) => norm(s.id) === serviceId) ?? null;

const townName = town?.name ?? titleCaseFromSlug(slug);
const serviceName = serviceObj?.name ?? titleCaseFromSlug(service);

const hiringQuestions = questionsByService[serviceId] ?? [
  "Are you licensed and insured?",
  "Do you provide written estimates?",
  "Do you offer a warranty on your work?",
];

const pageTitle = `Top ${serviceName} Companies in ${townName}, MA | Compare Local Pros`;
const metaDescription = `Find top ${serviceName.toLowerCase()} companies in ${townName}, MA. Compare local pros, view phone numbers, and choose the right provider near you.`;
const badgeExplanation =
  "Listings marked with a green Verified badge have confirmed business information.";

const sortCompanies = (items) =>
  items.slice().sort((a, b) => {
    const verifiedDiff =
      Number(isVerifiedCompany(b?.verified)) -
      Number(isVerifiedCompany(a?.verified));
    if (verifiedDiff !== 0) return verifiedDiff;
    return String(a?.name ?? "").localeCompare(String(b?.name ?? ""));
  });

const scoreCompanyForDedupe = (company) => {
  let score = 0;
  if (isVerifiedCompany(company?.verified)) score += 100;
  if (isDisplayableWebsite(company?.website)) score += 20;
  if (isDisplayableFacebook(company?.facebook)) score += 5;
  if (String(company?.description ?? "").trim()) score += 3;
  if (String(company?.name ?? "").trim()) score += 1;
  return score;
};

const shouldReplaceCompany = (incoming, existing) => {
  const incomingScore = scoreCompanyForDedupe(incoming);
  const existingScore = scoreCompanyForDedupe(existing);

  if (incomingScore !== existingScore) {
    return incomingScore > existingScore;
  }

  const incomingName = String(incoming?.name ?? "");
  const existingName = String(existing?.name ?? "");
  if (incomingName !== existingName) {
    return incomingName.localeCompare(existingName) < 0;
  }

  return String(incoming?.id ?? "").localeCompare(String(existing?.id ?? "")) < 0;
};

const dedupeCompaniesByPriority = (items) => {
  const selected = [];

  for (const item of items) {
    const websiteKey = normalizeWebsiteDomainForDedupe(item?.website);
    const phoneKey = normalizePhoneForDedupe(item?.phone);
    const nameKey = normalizeNameForDedupe(item?.name);

    const matchIndex = selected.findIndex((existing) => {
      const existingWebsiteKey = normalizeWebsiteDomainForDedupe(existing?.website);
      const existingPhoneKey = normalizePhoneForDedupe(existing?.phone);
      const existingNameKey = normalizeNameForDedupe(existing?.name);

      return (
        (websiteKey && existingWebsiteKey && websiteKey === existingWebsiteKey) ||
        (phoneKey && existingPhoneKey && phoneKey === existingPhoneKey) ||
        (nameKey && existingNameKey && nameKey === existingNameKey)
      );
    });

    if (matchIndex === -1) {
      selected.push(item);
      continue;
    }

    if (shouldReplaceCompany(item, selected[matchIndex])) {
      selected[matchIndex] = item;
    }
  }

  return sortCompanies(selected);
};

const limitStatewideFallback = (items, maxItems = 5) => {
  const deduped = dedupeCompaniesByPriority(items);
  const selected = [];
  const seenTowns = new Set();

  for (const item of deduped) {
    const townKey = norm(item?.townSlug);
    if (!townKey || seenTowns.has(townKey)) continue;

    seenTowns.add(townKey);
    selected.push(item);

    if (selected.length >= maxItems) break;
  }

  return selected;
};

const listingCompanies = companies.filter(
  (c) => norm(c?.townSlug) === townSlug && norm(c?.serviceId) === serviceId
);

const nearbyTownSlugs = nearbyTownsMap[townSlug] ?? [];

const nearbyAll = companies.filter((c) => {
  const companyTown = norm(c?.townSlug);
  const companyService = norm(c?.serviceId);
  return companyService === serviceId && nearbyTownSlugs.includes(companyTown);
});

const nearbyVerified = nearbyAll.filter((c) =>
  isVerifiedCompany(c?.verified)
);

const nearbyProviders =
  listingCompanies.length === 0
    ? (nearbyVerified.length > 0 ? nearbyVerified : nearbyAll)
    : [];

const statewideAll = companies.filter(
  (c) => norm(c?.serviceId) === serviceId
);

const statewideVerified = statewideAll.filter((c) =>
  isVerifiedCompany(c?.verified)
);

const statewideProviders =
  listingCompanies.length === 0 && nearbyProviders.length === 0
    ? (nearbyVerified.length > 0 ? statewideVerified : statewideAll).filter(
        (c) => norm(c?.townSlug) !== townSlug
      )
    : [];

const showingNearbyProviders =
  listingCompanies.length === 0 && nearbyProviders.length > 0;

const showingStatewideProviders =
  listingCompanies.length === 0 &&
  nearbyProviders.length === 0 &&
  statewideProviders.length > 0;

const displayCompanies =
  listingCompanies.length > 0
    ? dedupeCompaniesByPriority(listingCompanies).slice(0, 8)
    : nearbyProviders.length > 0
      ? dedupeCompaniesByPriority(nearbyProviders).slice(0, 8)
      : limitStatewideFallback(statewideProviders, 5);

const canonicalUrlRaw = `https://pronestne.com/ma/${townSlug}/${serviceId}/`.toLowerCase();
const canonicalHref = canonicalUrlRaw.replace(/\/+$/, "") + "/";

const nearbyLinkTowns = nearbyTownSlugs.slice(0, 3).map((slug) => ({
  slug,
  name: getTownNameFromSlug(slug),
}));

const nearbyLinksHtml = nearbyLinkTowns
  .map((place, index) => {
    const isLast = index === nearbyLinkTowns.length - 1;
    const isSecondLast = index === nearbyLinkTowns.length - 2;
    const separator = isLast
      ? ""
      : isSecondLast
        ? nearbyLinkTowns.length > 2
          ? ", and "
          : " and "
        : ", ";

    return `<a href="/ma/${place.slug}/${serviceId}/">${place.name}</a>${separator}`;
  })
  .join("");

const sameTownServiceLinks = services
  .filter((s) => norm(s?.id) !== serviceId)
  .map((s) => ({
    id: String(s.id),
    name: String(s.name),
    href: `/ma/${townSlug}/${String(s.id)}/`,
  }));

const sameTownServiceLinksHtml = sameTownServiceLinks
  .map((item, index) => {
    const isLast = index === sameTownServiceLinks.length - 1;
    const isSecondLast = index === sameTownServiceLinks.length - 2;
    const separator = isLast
      ? ""
      : isSecondLast
        ? sameTownServiceLinks.length > 2
          ? ", and "
          : " and "
        : ", ";

    return `<a href="${item.href}">${item.name}</a>${separator}`;
  })
  .join("");
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonicalHref} />

    <style>
      html,
      body {
        margin: 0;
        max-width: 100%;
        overflow-x: hidden;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      body {
        font-family: Arial, Helvetica, sans-serif;
        background: #f8fafc;
        color: #111827;
      }

      img,
      svg,
      iframe {
        max-width: 100%;
        height: auto;
      }

      .site-header {
        border-bottom: 1px solid #e5e7eb;
        background: #ffffff;
      }

      .header-inner {
        max-width: 1100px;
        margin: 0 auto;
        padding: 16px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
      }

      .brand-link {
        display: inline-flex;
        align-items: center;
        text-decoration: none;
        min-width: 0;
      }

      .brand-link img {
        display: block;
        height: 70px;
        width: auto;
      }

      .nav {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
        min-width: 0;
      }

      .nav a {
        text-decoration: none;
        color: #111827;
        font-weight: 600;
        font-size: 15px;
      }

      .page-wrap {
        max-width: 1100px;
        margin: 0 auto;
        padding: 24px 20px 60px;
        width: 100%;
      }

      .breadcrumbs {
        margin: 0 0 14px;
        font-size: 14px;
        color: #6b7280;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .breadcrumbs a {
        color: #4b5563;
        text-decoration: none;
      }

      .breadcrumbs a:hover {
        text-decoration: underline;
      }

      .breadcrumbs-sep {
        margin: 0 8px;
        color: #9ca3af;
      }

      .hero-title {
        margin: 0 0 10px;
        font-size: 34px;
        line-height: 1.15;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .page-intro {
        margin: 0 0 18px;
        font-size: 15px;
        color: #4b5563;
        max-width: 760px;
        line-height: 1.6;
      }

      .page-intro a {
        color: #2563eb;
        text-decoration: none;
      }

      .page-intro a:hover {
        text-decoration: underline;
      }

      .service-links-box {
        margin: 0 0 18px;
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 14px 16px;
        font-size: 14px;
        line-height: 1.5;
        color: #374151;
      }

      .service-links-box a {
        color: #2563eb;
        text-decoration: none;
      }

      .service-links-box a:hover {
        text-decoration: underline;
      }

      .section-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin: 0 0 18px;
        flex-wrap: wrap;
      }

      .section-head h2 {
        margin: 0;
        font-size: 28px;
        line-height: 1.2;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .nearby-intro {
        margin: 0 0 16px;
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        border-radius: 16px;
        padding: 14px 16px;
        color: #1e3a8a;
        font-size: 14px;
        line-height: 1.45;
      }

      .cards-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
        width: 100%;
      }

      .company-card {
        position: relative;
        display: flex;
        flex-direction: column;
        min-width: 0;
        width: 100%;
        height: 100%;
        border-radius: 18px;
        padding: 16px;
        overflow: hidden;
        transition: box-shadow 0.16s ease, border-color 0.16s ease;
      }

      .company-card.standard {
        background: #ffffff;
        border: 1.5px solid #d1d5db;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.06);
      }

      .company-card.standard:hover {
        box-shadow: 0 8px 18px rgba(0, 0, 0, 0.08);
        border-color: #c7d2fe;
      }

      .company-card.verified {
        background: linear-gradient(180deg, #f7fff9 0%, #eefcf3 100%);
        border: 2px solid #16a34a;
        box-shadow: 0 12px 28px rgba(22, 163, 74, 0.16);
      }

      .company-card.verified:hover {
        box-shadow: 0 18px 36px rgba(22, 163, 74, 0.22);
        border-color: #15803d;
      }

      .verified-top-bar {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 6px;
        background: linear-gradient(90deg, #16a34a 0%, #22c55e 100%);
        border-top-left-radius: 16px;
        border-top-right-radius: 16px;
      }

      .company-name {
        margin: 0 0 8px;
        font-size: 18px;
        line-height: 1.2;
        min-width: 0;
      }

      .company-name a {
        text-decoration: none;
        color: #111827;
        word-break: break-word;
        overflow-wrap: anywhere;
      }

      .company-name a:hover {
        text-decoration: underline;
      }

      .verified-badge-row {
        margin: 0 0 10px;
      }

      .based-in {
        margin: 0 0 10px;
        color: #4b5563;
        font-size: 14px;
        line-height: 1.35;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .company-description {
        margin: 0 0 6px;
        color: #374151;
        font-size: 14px;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 58px;
      }

      .phone-primary {
        margin-top: 6px;
      }

      .phone-btn {
        display: block;
        width: 100%;
        background: #16a34a;
        color: #ffffff;
        text-align: center;
        padding: 11px 12px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 700;
        font-size: 14px;
        line-height: 1.2;
        box-shadow: 0 8px 18px rgba(22, 163, 74, 0.22);
        transition: all 0.15s ease;
      }

      .phone-btn:hover {
        background: #15803d;
        transform: translateY(-1px);
        box-shadow: 0 10px 20px rgba(22, 163, 74, 0.3);
      }

      .info-line {
        margin-top: 6px;
        font-size: 13px;
        line-height: 1.35;
        color: #374151;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .info-line a {
        color: #334155;
        text-decoration: none;
        font-weight: 500;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .info-line a:hover {
        color: #1f2937;
        text-decoration: underline;
      }

      .button-wrap {
        margin-top: auto;
        padding-top: 6px;
      }

      .view-company-btn {
        display: inline-block;
        width: auto;
        text-align: center;
        background: #e5e7eb;
        color: #1f2937;
        padding: 7px 12px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 13px;
        line-height: 1.2;
        transition: all 0.15s ease;
      }

      .view-company-btn:hover {
        background: #d1d5db;
        transform: translateY(-1px);
      }

      .empty-state {
        margin: 0;
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 20px;
        color: #4b5563;
      }

      .hiring-tips {
        margin-top: 40px;
      }

      .hiring-tips h2 {
        margin: 0 0 12px;
        font-size: 24px;
        line-height: 1.2;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .hiring-tips p {
        margin: 0 0 10px;
        color: #4b5563;
      }

      .hiring-tips ul {
        margin: 0;
        padding-left: 18px;
      }

      .hiring-tips li {
        color: #4b5563;
      }

      .hiring-tips li + li {
        margin-top: 6px;
      }

      .seo-block {
        margin-top: 28px;
        max-width: 760px;
        font-size: 14px;
        line-height: 1.6;
        color: #6b7280;
      }

      .verified-dot {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: #16a34a;
        display: inline-block;
        flex: 0 0 auto;
      }

      .tooltip-wrap {
        position: relative;
        display: inline-flex;
        align-items: center;
        max-width: 100%;
      }

      .tooltip-trigger {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border: 0;
        background: transparent;
        padding: 0;
        margin: 0;
        cursor: pointer;
        font: inherit;
        max-width: 100%;
      }

      .verified-note .tooltip-trigger {
        font-size: 14px;
        color: #374151;
        white-space: nowrap;
      }

      .info-icon {
        color: #6b7280;
        font-size: 13px;
        line-height: 1;
      }

      .tooltip-bubble {
        position: absolute;
        left: 0;
        top: calc(100% + 8px);
        z-index: 20;
        width: 260px;
        max-width: 80vw;
        background: #111827;
        color: #ffffff;
        font-size: 13px;
        line-height: 1.4;
        padding: 10px 12px;
        border-radius: 10px;
        box-shadow: 0 10px 24px rgba(0, 0, 0, 0.18);
        opacity: 0;
        visibility: hidden;
        transform: translateY(-4px);
        transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s ease;
        text-align: left;
      }

      .tooltip-wrap:hover .tooltip-bubble,
      .tooltip-wrap:focus-within .tooltip-bubble {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
      }

      .verified-badge-trigger {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 11px;
        font-weight: 700;
        color: #14532d;
        background: #dcfce7;
        border: 1px solid #22c55e;
        padding: 4px 8px;
        border-radius: 999px;
        white-space: nowrap;
        max-width: 100%;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.65);
      }

      @media (min-width: 768px) {
        .cards-grid {
          grid-template-columns: repeat(3, minmax(0, 1fr));
          gap: 16px;
        }

        .company-card {
          padding: 20px;
        }

        .company-name {
          font-size: 20px;
          margin: 0 0 10px;
        }

        .company-description {
          font-size: 15px;
          margin: 0 0 8px;
          min-height: 64px;
        }

        .phone-btn {
          font-size: 15px;
          padding: 12px 14px;
        }

        .info-line {
          margin-top: 8px;
          font-size: 14px;
        }

        .verified-badge-trigger {
          font-size: 12px;
          padding: 4px 9px;
        }
      }

      @media (min-width: 1100px) {
        .cards-grid {
          grid-template-columns: repeat(4, minmax(0, 1fr));
        }
      }

      @media (max-width: 760px) {
        .header-inner {
          flex-direction: column;
          align-items: center;
          gap: 12px;
          text-align: center;
        }

        .nav {
          width: 100%;
          gap: 14px;
          justify-content: center;
          flex-wrap: wrap;
        }

        .brand-link img {
          height: 60px;
        }

        .page-wrap {
          padding: 20px 12px 48px;
        }

        .breadcrumbs {
          font-size: 13px;
        }

        .hero-title {
          font-size: 28px;
        }

        .page-intro {
          font-size: 14px;
          margin: 0 0 16px;
        }

        .service-links-box {
          font-size: 13px;
          padding: 12px 14px;
        }

        .section-head h2 {
          font-size: 22px;
        }

        .hiring-tips h2 {
          font-size: 22px;
        }

        .cards-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
          gap: 10px;
        }

        .company-card {
          padding: 10px;
          border-radius: 16px;
        }

        .company-name {
          font-size: 15px;
          margin: 0 0 6px;
        }

        .verified-badge-row {
          margin: 0 0 8px;
        }

        .verified-badge-trigger {
          font-size: 10px;
          padding: 3px 6px;
        }

        .based-in {
          margin: 0 0 8px;
          font-size: 12px;
          line-height: 1.3;
        }

        .company-description {
          margin: 0 0 6px;
          font-size: 12px;
          line-height: 1.3;
          -webkit-line-clamp: 4;
          min-height: 62px;
        }

        .phone-primary {
          margin-top: 6px;
        }

        .phone-btn {
          padding: 9px 8px;
          font-size: 12px;
          border-radius: 8px;
        }

        .info-line {
          margin-top: 5px;
          font-size: 12px;
          line-height: 1.3;
        }

        .button-wrap {
          padding-top: 6px;
        }

        .view-company-btn {
          padding: 7px 10px;
          font-size: 11px;
          border-radius: 7px;
        }

        .verified-note .tooltip-trigger {
          white-space: normal;
        }

        .nearby-intro {
          font-size: 13px;
          padding: 12px 14px;
        }
      }
    </style>
  </head>

  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="brand-link">
          <img src="/logo.png" alt="ProNest New England logo" />
        </a>

        <nav class="nav">
          <a href="/">Home</a>
          <a href="/ma/">Massachusetts</a>
          <a href="/claim/">Claim Listing</a>
        </nav>
      </div>
    </header>

    <main class="page-wrap">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumbs-sep">›</span>
        <a href="/ma/">Massachusetts</a>
        <span class="breadcrumbs-sep">›</span>
        <a href={`/ma/${slug}/`}>{townName}</a>
        <span class="breadcrumbs-sep">›</span>
        <span>{serviceName}</span>
      </nav>

      <h1 class="hero-title">
  {serviceName} in {townName}, MA – Compare Local Companies
</h1>

      <p class="page-intro">
  Need {serviceName.toLowerCase()} in {townName}, MA? Compare local companies, see phone numbers instantly, and choose a trusted provider near you.
        {nearbyLinkTowns.length > 0 && (
          <>
            {" "}Browse nearby {serviceName.toLowerCase()} services in <Fragment set:html={nearbyLinksHtml} />.{" "}
          </>
        )}
      </p>

      {sameTownServiceLinks.length > 0 && (
        <div class="service-links-box">
          Also explore other home services in {townName}: <Fragment set:html={sameTownServiceLinksHtml} />.
        </div>
      )}

      <div class="section-head">
        <h2>
          {showingNearbyProviders
            ? `Nearby ${serviceName} Providers for ${townName}`
            : showingStatewideProviders
              ? `${serviceName} Providers for ${townName}`
              : `${serviceName} Companies in ${townName}`}
        </h2>

        <div class="verified-note">
          <div class="tooltip-wrap">
            <button
              type="button"
              class="tooltip-trigger"
              aria-label="What the Verified badge means"
            >
              <span class="verified-dot" aria-hidden="true"></span>
              <span>Verified</span>
              <span class="info-icon" aria-hidden="true">ⓘ</span>
            </button>
            <div class="tooltip-bubble">{badgeExplanation}</div>
          </div>
        </div>
      </div>

      {
        showingNearbyProviders && (
          <p class="nearby-intro">
            No {serviceName.toLowerCase()} companies are currently listed in {townName}. Showing nearby providers from {nearbyTownSlugs.map(getTownNameFromSlug).join(", ")}.
          </p>
        )
      }

      {
        showingStatewideProviders && (
          <p class="nearby-intro">
            No {serviceName.toLowerCase()} companies are currently listed in {townName}, and no nearby-town matches were found. Showing a limited selection of providers from other Massachusetts towns.
          </p>
        )
      }

      {
        displayCompanies.length === 0 ? (
          <p class="empty-state">
            No {serviceName.toLowerCase()} companies are listed yet for {townName}, Massachusetts.
          </p>
        ) : (
          <section class="cards-grid">
            {displayCompanies.map((company) => {
              const verified = isVerifiedCompany(company?.verified);
              const websiteUrl = normalizeWebsiteUrl(company?.website);
              const facebookUrl = normalizeFacebookUrl(company?.facebook);
              const showWebsite = isDisplayableWebsite(company?.website);
              const showFacebook = isDisplayableFacebook(company?.facebook);
              const phoneHref = getPhoneHref(company?.phone);
              const languages = splitLanguages(company?.languages);

              return (
                <article class={`company-card ${verified ? "verified" : "standard"}`}>
                  {verified && <div class="verified-top-bar"></div>}

                  <h2 class="company-name">
                    <a href={`/ma/${company.townSlug}/${company.serviceId}/${company.id}/`}>
                      {company?.name}
                    </a>
                  </h2>

                  {verified && (
                    <div class="verified-badge-row">
                      <span class="verified-badge-trigger">
                        <span
                          style="width:8px;height:8px;border-radius:999px;background:#16a34a;display:inline-block;"
                          aria-hidden="true"
                        ></span>
                        <span>Verified</span>
                      </span>
                    </div>
                  )}

                  <p class="based-in">
                    Based in {getTownNameFromSlug(company?.townSlug)}, MA
                  </p>

                  <p class="company-description">
                    {company?.description
                      ? company.description
                      : `Local ${serviceName.toLowerCase()} services in ${townName}, MA.`}
                  </p>

                  {company?.phone && phoneHref && (
                    <div class="phone-primary">
                      <a href={phoneHref} class="phone-btn">📞 {company.phone}</a>
                    </div>
                  )}

                  {showWebsite && (
                    <div class="info-line">
                      <strong>Website:</strong>{" "}
                      <a href={websiteUrl} target="_blank" rel="nofollow noopener noreferrer">
                        {getDisplayDomain(company?.website)}
                      </a>
                    </div>
                  )}

                  {showFacebook && (
                    <div class="info-line">
                      <strong>Facebook:</strong>{" "}
                      <a href={facebookUrl} target="_blank" rel="nofollow noopener noreferrer">
                        Facebook Page
                      </a>
                    </div>
                  )}

                  {languages.primary && (
                    <div class="info-line">
                      <strong>Languages:</strong> {languages.primary}
                      {languages.additional.length > 0 ? ` + ${languages.additional.length} more` : ""}
                    </div>
                  )}

                  <div class="button-wrap">
                    <a
                      href={`/ma/${company.townSlug}/${company.serviceId}/${company.id}/`}
                      class="view-company-btn"
                    >
                      View company
                    </a>
                  </div>
                </article>
              );
            })}
          </section>
        )
      }

      <section class="hiring-tips">
        <h2>Questions to Ask Before Hiring a {serviceName} Contractor in {townName}, MA</h2>

        <ul>
          <li>Are you licensed and insured in Massachusetts?</li>
          <li>How much experience do you have with this type of work?</li>
          <li>Can you provide references from recent local jobs?</li>
          <li>What does your estimate include, and are there potential extra costs?</li>
          <li>What is your expected timeline for this project?</li>
          <li>Do you offer any warranties or guarantees on your work?</li>
        </ul>
      </section>

      <p class="seo-block">
        Finding the right {serviceName.toLowerCase()} in {townName}, MA doesn’t have to be complicated. Compare local providers, ask the right questions, and choose a company that offers clear pricing, strong communication, and dependable service you can trust.
      </p>

    </main>
  </body>
</html>