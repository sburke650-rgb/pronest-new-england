---
export const prerender = true;

import towns from "../../../data/towns/ma-towns.json";
import companies from "../../../data/companies/ma-companies.json";
import services from "../../../data/services/ma-services.json";

const norm = (v) => String(v ?? "").trim().toLowerCase();

const titleCaseFromSlug = (v) =>
  String(v ?? "")
    .split("-")
    .filter(Boolean)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");

const getTownNameFromSlug = (slug) => {
  const town = towns.find((t) => norm(t.slug) === norm(slug));
  return town?.name ?? titleCaseFromSlug(slug);
};

const normalizeWebsiteUrl = (url) => {
  const raw = String(url ?? "").trim();
  if (!raw) return "";

  const cleaned = raw.replace(/\s+/g, "").replace(/\/+$/, "");
  const withProtocol = /^https?:\/\//i.test(cleaned) ? cleaned : `https://${cleaned}`;

  try {
    const parsed = new URL(withProtocol);
    if (!parsed.hostname || parsed.hostname === "localhost") return "";
    parsed.hash = "";
    if (parsed.pathname === "/") parsed.pathname = "";
    return parsed.toString().replace(/\/$/, "");
  } catch {
    return "";
  }
};

const getDisplayDomain = (url) => {
  const normalized = normalizeWebsiteUrl(url);
  if (!normalized) return "";

  try {
    const parsed = new URL(normalized);
    return parsed.hostname.replace(/^www\./, "");
  } catch {
    return "";
  }
};

const getPhoneHref = (phone) => {
  const raw = String(phone ?? "").trim();
  if (!raw) return "";
  const digits = raw.replace(/[^\d+]/g, "");
  return digits ? `tel:${digits}` : "";
};

const normalizePhoneForDedupe = (phone) => {
  const digits = String(phone ?? "").replace(/\D/g, "").trim();
  return digits.length === 11 && digits.startsWith("1") ? digits.slice(1) : digits;
};

const normalizeFacebookUrl = (url) => {
  const raw = String(url ?? "").trim();
  if (!raw) return "";

  const cleaned = raw.replace(/\s+/g, "").replace(/\/+$/, "");
  const withProtocol = /^https?:\/\//i.test(cleaned) ? cleaned : `https://${cleaned}`;

  try {
    const parsed = new URL(withProtocol);
    const host = parsed.hostname.toLowerCase().replace(/^www\./, "");
    const path = parsed.pathname.replace(/\/+$/, "");

    if (host !== "facebook.com" && host !== "m.facebook.com") return "";
    if (!path || path === "/") return "";

    parsed.hash = "";
    return parsed.toString().replace(/\/$/, "");
  } catch {
    return "";
  }
};

const normalizeWebsiteDomainForDedupe = (url) => {
  const normalized = normalizeWebsiteUrl(url);
  if (!normalized) return "";

  try {
    const parsed = new URL(normalized);
    return parsed.hostname.toLowerCase().replace(/^www\./, "").trim();
  } catch {
    return "";
  }
};

const normalizeNameForDedupe = (name) =>
  String(name ?? "")
    .toLowerCase()
    .replace(/&/g, " and ")
    .replace(/[^a-z0-9]+/g, " ")
    .replace(
      /\b(inc|incorporated|llc|l l c|co|company|corp|corporation|ltd|limited)\b/g,
      " "
    )
    .replace(/\s+/g, " ")
    .trim();

const isDisplayableWebsite = (url) => {
  const normalized = normalizeWebsiteUrl(url);
  if (!normalized) return false;

  try {
    const parsed = new URL(normalized);
    const host = parsed.hostname.toLowerCase().replace(/^www\./, "");
    return host !== "facebook.com" && host !== "m.facebook.com";
  } catch {
    return false;
  }
};

const isDisplayableFacebook = (url) => {
  return normalizeFacebookUrl(url) !== "";
};

const formatLanguages = (langs) => {
  if (!langs) return [];

  if (Array.isArray(langs)) {
    return langs.map((x) => String(x).trim()).filter(Boolean);
  }

  if (typeof langs === "string") {
    return langs
      .split(",")
      .map((x) => x.trim())
      .filter(Boolean);
  }

  return [];
};

const splitLanguages = (langs) => {
  const cleaned = formatLanguages(langs);
  return {
    primary: cleaned[0] ?? "",
    additional: cleaned.slice(1),
  };
};

const isVerifiedCompany = (value) => {
  const v = String(value ?? "").trim().toLowerCase();
  return value === true || v === "true" || v === "1" || v === "yes";
};

const questionsByService = {
