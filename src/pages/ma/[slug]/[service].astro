---
export const prerender = true;

import towns from "../../../data/towns/ma-towns.json";
import companies from "../../../data/companies/ma-companies.json";
import services from "../../../data/services/ma-services.json";

const norm = (v) => String(v ?? "").trim().toLowerCase();

const titleCaseFromSlug = (v) =>
  String(v ?? "")
    .split("-")
    .filter(Boolean)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");

const getTownNameFromSlug = (slug) => {
  const town = towns.find((t) => norm(t.slug) === norm(slug));
  return town?.name ?? titleCaseFromSlug(slug);
};

const getServiceNameFromId = (id) => {
  const service = services.find((s) => norm(s.id) === norm(id));
  return service?.name ?? titleCaseFromSlug(id);
};

const normalizeWebsiteUrl = (url) => {
  const raw = String(url ?? "").trim();
  if (!raw) return "";
  if (/^https?:\/\//i.test(raw)) return raw;
  return `https://${raw}`;
};

const getPhoneHref = (phone) => {
  const raw = String(phone ?? "").trim();
  if (!raw) return "";
  const digits = raw.replace(/[^\d+]/g, "");
  return digits ? `tel:${digits}` : "";
};

const formatLanguages = (langs) => {
  if (!langs) return [];

  if (Array.isArray(langs)) {
    return langs.map((x) => String(x).trim()).filter(Boolean);
  }

  if (typeof langs === "string") {
    return langs
      .split(",")
      .map((x) => x.trim())
      .filter(Boolean);
  }

  return [];
};

const splitLanguages = (langs) => {
  const cleaned = formatLanguages(langs);
  return {
    primary: cleaned[0] ?? "",
    additional: cleaned.slice(1),
  };
};

const isVerifiedCompany = (value) => {
  const v = String(value ?? "").trim().toLowerCase();
  return value === true || v === "true" || v === "1" || v === "yes";
};

const questionsByService = {
  electrician: [
    "Are you licensed and insured?",
    "Do you provide written estimates?",
    "Do you offer a warranty on your work?",
  ],
  hvac: [
    "Are you licensed and insured?",
    "Do you provide written estimates?",
    "Do you offer a warranty on your work?",
  ],
  painters: [
    "Are you licensed and insured?",
    "Do you provide written estimates?",
    "Do you offer a warranty on your work?",
  ],
  "pest-control": [
    "Are you licensed and insured?",
    "Do you provide written estimates?",
    "Do you offer a warranty on your work?",
  ],
  plumbing: [
    "Are you licensed and insured?",
    "Do you provide written estimates?",
    "Do you offer a warranty on your work?",
  ],
  "pressure-washing": [
    "Are you licensed and insured?",
    "Do you provide written estimates?",
    "Do you offer a warranty on your work?",
  ],
  roofing: [
    "Are you licensed and insured?",
    "Do you provide written estimates?",
    "Do you offer a warranty on your work?",
  ],
  "yard-landscaping": [
    "Are you licensed and insured?",
    "Do you provide written estimates?",
    "Do you offer a warranty on your work?",
  ],
};

export function getStaticPaths() {
  const paths = [];

  for (const town of towns) {
    for (const service of services) {
      if (!town?.slug || !service?.id) continue;

      paths.push({
        params: {
          slug: String(town.slug),
          service: String(service.id),
        },
      });
    }
  }

  return paths;
}

const { slug, service } = Astro.params;

const townSlug = norm(slug);
const serviceId = norm(service);

const town = towns.find((t) => norm(t.slug) === townSlug) ?? null;
const serviceObj = services.find((s) => norm(s.id) === serviceId) ?? null;

const townName = town?.name ?? titleCaseFromSlug(slug);
const serviceName = serviceObj?.name ?? titleCaseFromSlug(service);

const hiringQuestions = questionsByService[serviceId] ?? [
  "Are you licensed and insured?",
  "Do you provide written estimates?",
  "Do you offer a warranty on your work?",
];

const pageTitle = `${townName} ${serviceName} Companies | ProNest New England`;
const badgeExplanation =
  "Listings marked with a green Verified badge indicate businesses with confirmed listing information.";

const listingCompanies = companies
  .filter(
    (c) => norm(c?.townSlug) === townSlug && norm(c?.serviceId) === serviceId
  )
  .sort((a, b) => {
    const verifiedDiff =
      Number(isVerifiedCompany(b?.verified)) -
      Number(isVerifiedCompany(a?.verified));
    if (verifiedDiff !== 0) return verifiedDiff;
    return String(a?.name ?? "").localeCompare(String(b?.name ?? ""));
  });
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>

    <style>
      body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background: #f8fafc;
        color: #111827;
      }

      .site-header {
        border-bottom: 1px solid #e5e7eb;
        background: #ffffff;
      }

      .header-inner {
        max-width: 1100px;
        margin: 0 auto;
        padding: 16px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .brand-link {
        display: inline-flex;
        align-items: center;
        text-decoration: none;
      }

      .brand-link img {
        display: block;
        height: 70px;
        width: auto;
      }

      .nav {
        display: flex;
        gap: 20px;
      }

      .nav a {
        text-decoration: none;
        color: #111827;
        font-weight: 600;
        font-size: 15px;
      }

      .page-wrap {
        max-width: 1100px;
        margin: 0 auto;
        padding: 24px 20px 60px;
      }

      .breadcrumbs {
        margin: 0 0 14px;
        font-size: 14px;
        color: #6b7280;
      }

      .breadcrumbs a {
        color: #4b5563;
        text-decoration: none;
      }

      .breadcrumbs a:hover {
        text-decoration: underline;
      }

      .breadcrumbs-sep {
        margin: 0 8px;
        color: #9ca3af;
      }

      .hero-title {
        margin: 0 0 24px;
        font-size: 34px;
        line-height: 1.15;
      }

      .section-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin: 0 0 18px;
        flex-wrap: wrap;
      }

      .section-head h2 {
        margin: 0;
        font-size: 28px;
        line-height: 1.2;
      }

      .verified-note {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 14px;
        color: #374151;
        cursor: help;
        white-space: nowrap;
      }

      .verified-dot {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: #16a34a;
        display: inline-block;
        flex: 0 0 auto;
      }

      .info-icon {
        color: #6b7280;
        font-size: 13px;
        line-height: 1;
      }

      .cards-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
      }

      .info-line {
        margin-top: 10px;
        font-size: 14px;
        color: #374151;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .info-line a {
        color: #2563eb;
        text-decoration: none;
      }

      .info-line a:hover {
        text-decoration: underline;
      }

      .empty-state {
        margin: 0;
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 20px;
        color: #4b5563;
      }

      .hiring-tips {
        margin-top: 40px;
      }

      .hiring-tips h2 {
        margin: 0 0 12px;
        font-size: 24px;
        line-height: 1.2;
      }

      .hiring-tips p {
        margin: 0 0 10px;
        color: #4b5563;
      }

      .hiring-tips ul {
        margin: 0;
        padding-left: 18px;
      }

      .hiring-tips li {
        color: #4b5563;
      }

      .hiring-tips li + li {
        margin-top: 6px;
      }

      @media (min-width: 768px) {
        .cards-grid {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }
      }

      @media (min-width: 1100px) {
        .cards-grid {
          grid-template-columns: repeat(4, minmax(0, 1fr));
        }
      }

      @media (max-width: 760px) {
        .header-inner {
          flex-direction: column;
          align-items: flex-start;
          gap: 12px;
        }

        .nav {
          flex-wrap: wrap;
          gap: 14px;
        }

        .brand-link img {
          height: 60px;
        }

        .cards-grid {
          grid-template-columns: 1fr;
        }

        .hero-title {
          font-size: 28px;
        }

        .section-head h2 {
          font-size: 22px;
        }

        .verified-note {
          white-space: normal;
        }

        .hiring-tips h2 {
          font-size: 22px;
        }
      }
    </style>
  </head>

  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="brand-link">
          <img src="/logo.png" alt="ProNest New England logo" />
        </a>

        <nav class="nav">
          <a href="/">Home</a>
          <a href="/ma/">Massachusetts</a>
          <a href="/claim/">Claim Listing</a>
        </nav>
      </div>
    </header>

    <main class="page-wrap">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumbs-sep">›</span>
        <a href="/ma/">Massachusetts</a>
        <span class="breadcrumbs-sep">›</span>
        <a href={`/ma/${slug}/`}>{townName}</a>
        <span class="breadcrumbs-sep">›</span>
        <span>{serviceName}</span>
      </nav>

      <h1 class="hero-title">
        {townName}, Massachusetts {serviceName} Companies
      </h1>

      <div class="section-head">
        <h2>{serviceName} Companies in {townName}</h2>

        <div
          class="verified-note"
          title={badgeExplanation}
          aria-label={badgeExplanation}
        >
          <span class="verified-dot" aria-hidden="true"></span>
          <span>Verified</span>
          <span class="info-icon" aria-hidden="true">ⓘ</span>
        </div>
      </div>

      {
        listingCompanies.length === 0 ? (
          <p class="empty-state">
            No {serviceName.toLowerCase()} companies are listed yet for {townName}, Massachusetts.
          </p>
        ) : (
          <section class="cards-grid">
            {listingCompanies.map((company) => {
              const verified = isVerifiedCompany(company?.verified);
              const websiteUrl = normalizeWebsiteUrl(company?.website);
              const phoneHref = getPhoneHref(company?.phone);
              const languages = splitLanguages(company?.languages);

              const cardStyle = verified
                ? "background:#f0fdf4;border:3px solid #16a34a;border-radius:16px;padding:20px;box-shadow:0 12px 28px rgba(22,163,74,0.18);position:relative;"
                : "background:#ffffff;border:1px solid #e5e7eb;border-radius:16px;padding:20px;box-shadow:0 2px 6px rgba(0,0,0,0.05);";

              return (
                <article style={cardStyle}>
                  {verified && (
                    <div style="position:absolute;top:0;left:0;right:0;height:6px;background:#16a34a;border-top-left-radius:14px;border-top-right-radius:14px;"></div>
                  )}

                  <h2 style="margin:0 0 10px;font-size:20px;">
                    <a href={`/ma/${company.townSlug}/${company.serviceId}/${company.id}/`} style="text-decoration:none;color:#111827;">
                      {company?.name}
                    </a>
                  </h2>

                  {verified && (
                    <span
                      style="display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:700;color:#166534;background:#dcfce7;border:1px solid #22c55e;padding:4px 8px;border-radius:999px;cursor:help;"
                      title={badgeExplanation}
                      aria-label="Verified listing"
                    >
                      <span style="width:8px;height:8px;border-radius:999px;background:#16a34a;display:inline-block;" aria-hidden="true"></span>
                      Verified
                    </span>
                  )}

                  <p style="margin:10px 0;color:#4b5563;font-size:14px;">
                    Based in {getTownNameFromSlug(company?.townSlug)}, MA
                  </p>

                  {company?.description && (
                    <p style="margin:0 0 12px;color:#374151;font-size:15px;">
                      {company.description}
                    </p>
                  )}

                  {company?.phone && (
                    <div class="info-line">
                      <strong>Phone:</strong>{" "}
                      <a href={phoneHref}>{company.phone}</a>
                    </div>
                  )}

                  {company?.website && (
                    <div class="info-line">
                      <strong>Website:</strong>{" "}
                      <a href={websiteUrl} target="_blank" rel="noopener noreferrer">
                        {company.website}
                      </a>
                    </div>
                  )}

                  {languages.primary && (
                    <div class="info-line">
                      <strong>Languages:</strong> {languages.primary}
                      {languages.additional.length > 0 ? ` + ${languages.additional.length} more` : ""}
                    </div>
                  )}

                  <div style="margin-top:14px;">
                    <a href={`/ma/${company.townSlug}/${company.serviceId}/${company.id}/`} style="background:#2563eb;color:#fff;padding:10px 14px;border-radius:10px;text-decoration:none;font-weight:700;">
                      View company
                    </a>
                  </div>
                </article>
              );
            })}
          </section>
        )
      }

      <section class="hiring-tips">
        <h2>Hiring Tips for {serviceName} in {townName}</h2>

        <p>Before hiring, consider asking:</p>

        <ul>
          {hiringQuestions.map((item) => <li>{item}</li>)}
        </ul>
      </section>
    </main>
  </body>
</html>