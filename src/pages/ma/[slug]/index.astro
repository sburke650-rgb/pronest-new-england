---
export const prerender = true;

import towns from "../../../data/towns/ma-towns.json";
import companies from "../../../data/companies/ma-companies.json";
import services from "../../../data/services/ma-services.json";

const norm = (v) => String(v ?? "").trim().toLowerCase();

export function getStaticPaths() {
  return towns.map((t) => ({
    params: { slug: String(t.slug) },
  }));
}

const { slug } = Astro.params;
const townSlug = norm(slug);

const town = towns.find((t) => norm(t.slug) === townSlug) ?? null;
const townName = town?.name ?? slug;

// Companies in this town
const companiesInTown = companies.filter(
  (c) => norm(c?.townSlug) === townSlug
);

// Service IDs used in this town
const serviceIdsInTown = Array.from(
  new Set(
    companiesInTown
      .map((c) => norm(c?.serviceId))
      .filter(Boolean)
  )
);

// Service objects for this town (services with local providers)
const servicesInTown = services
  .filter((s) => serviceIdsInTown.includes(norm(s.id)))
  .slice()
  .sort((a, b) => String(a.name).localeCompare(String(b.name)));

// All services for crawl/internal linking
const allServices = services
  .slice()
  .sort((a, b) => String(a.name).localeCompare(String(b.name)));

// Secondary services = services without local providers yet
const secondaryServices = allServices.filter(
  (s) => !serviceIdsInTown.includes(norm(s.id))
);

// Local providers
const providersSorted = companiesInTown
  .slice()
  .sort((a, b) => {
    const aVerified =
      a?.verified === true || norm(a?.claimStatus) === "verified" ? 1 : 0;
    const bVerified =
      b?.verified === true || norm(b?.claimStatus) === "verified" ? 1 : 0;
    if (bVerified !== aVerified) return bVerified - aVerified;
    return String(a?.name ?? "").localeCompare(String(b?.name ?? ""));
  });

// 🔥 STATEWIDE FALLBACK (only when NO local providers)
const fallbackProviders =
  providersSorted.length === 0
    ? companies
        .slice()
        .sort((a, b) => {
          const aVerified =
            a?.verified === true || norm(a?.claimStatus) === "verified" ? 1 : 0;
          const bVerified =
            b?.verified === true || norm(b?.claimStatus) === "verified" ? 1 : 0;
          if (bVerified !== aVerified) return bVerified - aVerified;
          return String(a?.name ?? "").localeCompare(String(b?.name ?? ""));
        })
        .slice(0, 10)
    : [];

const canonicalUrl = `https://pronestne.com/ma/${townSlug}/`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{townName}, Massachusetts • ProNest New England</title>
    <meta
      name="description"
      content={`Browse service categories and local providers in ${townName}, Massachusetts.`}
    />
    <link rel="canonical" href={canonicalUrl} />

    <style>
      :root {
        font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      }

      body {
        margin: 0;
        background: #fff;
        color: #111827;
      }

      .wrap {
        max-width: 1000px;
        margin: 0 auto;
        padding: 32px 16px 56px;
      }

      .breadcrumbs {
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 16px;
        line-height: 1.6;
      }

      .breadcrumbs a {
        color: inherit;
        text-decoration: none;
        border-bottom: 1px solid rgba(0, 0, 0, 0.15);
      }

      .hero {
        margin-bottom: 26px;
      }

      h1 {
        margin: 0 0 10px 0;
        font-size: 36px;
      }

      .intro {
        margin: 0;
        max-width: 760px;
        font-size: 17px;
        color: #374151;
      }

      .section {
        margin-top: 26px;
        padding: 22px;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
      }

      .section h2 {
        margin-top: 0;
      }

      .section-intro {
        margin: 0 0 14px 0;
        color: #4b5563;
        font-size: 15px;
        line-height: 1.55;
      }

      .services-grid {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 10px;
      }

      .services-grid li {
        margin: 0;
      }

      .service-link {
        display: block;
        padding: 14px;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        text-decoration: none;
        color: #111827;
        font-weight: 600;
        background: #f9fafb;
      }

      .service-link:hover {
        background: #f3f4f6;
      }

      .service-link.featured {
        background: #eff6ff;
        border-color: #bfdbfe;
      }

      .service-link.featured:hover {
        background: #dbeafe;
      }

      .providers-list {
        list-style: none;
        padding: 0;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 10px;
      }

      .provider-link {
        display: block;
        padding: 14px;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        text-decoration: none;
        color: #111827;
      }

      .provider-name {
        display: block;
        font-weight: 700;
      }

      .provider-meta {
        display: block;
        font-size: 14px;
        color: #6b7280;
        margin-top: 4px;
      }

      .verified-badge {
        display: inline-block;
        margin-top: 6px;
        font-size: 12px;
        padding: 4px 8px;
        border-radius: 999px;
        background: rgba(34, 197, 94, 0.12);
        color: rgb(22, 101, 52);
      }

      .nearby-badge {
        display: inline-block;
        margin-top: 6px;
        margin-right: 6px;
        font-size: 12px;
        padding: 4px 8px;
        border-radius: 999px;
        background: rgba(59, 130, 246, 0.08);
        color: #1d4ed8;
      }
    </style>
  </head>

  <body>
    <main class="wrap">

      <section class="hero">
        <h1>{townName}, Massachusetts</h1>
        <p class="intro">
          Browse service categories and provider pages for {townName}, Massachusetts.
        </p>
      </section>

      {servicesInTown.length > 0 && (
        <section class="section">
          <h2>Featured services in {townName}</h2>
          <p class="section-intro">
            These service categories already have local provider pages in {townName}.
          </p>

          <ul class="services-grid">
            {servicesInTown.map((s) => (
              <li>
                <a class="service-link featured" href={`/ma/${townSlug}/${norm(s.id)}/`}>
                  {s.name}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {secondaryServices.length > 0 && (
        <section class="section">
          <h2>All service categories</h2>
          <p class="section-intro">
            Additional services available in nearby areas or expanding into {townName}.
          </p>

          <ul class="services-grid">
            {secondaryServices.map((s) => (
              <li>
                <a class="service-link" href={`/ma/${townSlug}/${norm(s.id)}/`}>
                  {s.name}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {/* ✅ LOCAL PROVIDERS */}
      {providersSorted.length > 0 && (
        <section class="section">
          <h2>Local providers</h2>

          <ul class="providers-list">
            {providersSorted.map((c) => {
              const serviceObj = services.find((s) => norm(s.id) === norm(c.serviceId));
              const serviceName = serviceObj?.name ?? c.serviceId;
              const isVerified =
                c?.verified === true || norm(c?.claimStatus) === "verified";

              return (
                <li>
                  <a href={`/ma/${townSlug}/${norm(c.serviceId)}/${c.id}/`} class="provider-link">
                    <span class="provider-name">{c.name}</span>
                    <span class="provider-meta">{serviceName}</span>
                    {isVerified && <span class="verified-badge">Verified</span>}
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      )}

      {/* 🔥 FALLBACK */}
      {providersSorted.length === 0 && fallbackProviders.length > 0 && (
        <section class="section">
          <h2>Nearby providers</h2>
          <p class="section-intro">
            We’re expanding coverage in {townName}. Here are providers from nearby areas.
          </p>

          <ul class="providers-list">
            {fallbackProviders.map((c) => {
              const serviceObj = services.find((s) => norm(s.id) === norm(c.serviceId));
              const serviceName = serviceObj?.name ?? c.serviceId;
              const providerTown =
                towns.find((t) => norm(t.slug) === norm(c.townSlug))?.name ??
                c.townSlug;

              const isVerified =
                c?.verified === true || norm(c?.claimStatus) === "verified";

              return (
                <li>
                  <a href={`/ma/${norm(c.townSlug)}/${norm(c.serviceId)}/${c.id}/`} class="provider-link">
                    <span class="provider-name">{c.name}</span>
                    <span class="provider-meta">
                      {serviceName} • {providerTown}
                    </span>
                    <span class="nearby-badge">Nearby</span>
                    {isVerified && <span class="verified-badge">Verified</span>}
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      )}

    </main>
  </body>
</html>