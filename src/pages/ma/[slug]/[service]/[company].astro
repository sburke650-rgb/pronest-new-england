---
export const prerender = true;

import towns from "../../../../data/towns/ma-towns.json";
import companies from "../../../../data/companies/ma-companies.json";
import services from "../../../../data/services/ma-services.json";

export function getStaticPaths() {
  const norm = (v) => String(v ?? "").trim().toLowerCase();
  const paths = [];

  for (const c of companies) {
    if (!c?.townSlug || !c?.serviceId || !c?.id) continue;

    paths.push({
      params: {
        slug: String(c.townSlug),
        service: String(c.serviceId),
        company: String(c.id),
      },
    });
  }

  return paths;
}

const norm = (v) => String(v ?? "").trim().toLowerCase();

const { slug, service, company: companyParam } = Astro.params;
const urlTown = norm(slug);
const urlService = norm(service);
const urlCompanyId = norm(companyParam);

const company =
  companies.find(
    (c) =>
      norm(c.id) === urlCompanyId &&
      norm(c.townSlug) === urlTown &&
      norm(c.serviceId) === urlService
  ) ?? null;

if (!company) return new Response("Not Found", { status: 404 });

const town = towns.find((t) => norm(t.slug) === urlTown) ?? null;
const serviceObj = services.find((s) => norm(s.id) === urlService) ?? null;

const townName = town?.name ?? company.townSlug;
const serviceName = serviceObj?.name ?? company.serviceId;

const isVerified = company?.verified === true || company?.claimStatus === "verified";
const isClaimed = company?.claimed === true || company?.claimStatus === "claimed";

/* ✅ NEW CTR-OPTIMIZED TITLE */
const title = isVerified
  ? `${company.name} – ${townName}, MA | Verified ${serviceName} (Phone & Services)`
  : `${company.name} – ${townName}, MA | Phone, Services & Local Info`;

/* ✅ NEW CTR META DESCRIPTION */
const description =
  company?.description && company.description.trim().length > 0
    ? String(company.description)
    : `Call ${company.name} in ${townName}, MA for ${serviceName.toLowerCase()} services. View phone number, services, and business details. Compare with other local providers near you.`;

const canonicalRaw = `https://pronestne.com/ma/${company.townSlug}/${company.serviceId}/${company.id}/`.toLowerCase();
const canonicalHref = canonicalRaw.replace(/\/+$/, "") + "/";

const cleanPhone = String(company?.phone ?? "").replace(/[^0-9+]/g, "");

/* Make Google Maps search more specific */
const googleMapsQuery = encodeURIComponent(
  `${company.name} ${serviceName} ${townName} MA`
);
const googleMapsUrl = `https://www.google.com/maps/search/?api=1&query=${googleMapsQuery}`;
---

<!doctype html>
<html lang="en">
<head>

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalHref} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": company.name,
  "description": description,
  "telephone": company.phone ?? undefined,
  "url": canonicalHref,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": townName,
    "addressRegion": "MA",
    "addressCountry": "US"
  }
})}></script>

<style>

body {
  margin:0;
  font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
  background:#fff;
  color:#111;
}

main {
  max-width:900px;
  margin:28px auto;
  padding:0 16px 50px;
}

.crumbs {
  font-size:14px;
  color:#666;
  margin-bottom:14px;
  line-height:1.6;
}

.crumbs a {
  text-decoration:none;
  border-bottom:1px solid rgba(0,0,0,0.15);
}

.crumbs a:hover {
  border-bottom-color:rgba(0,0,0,0.35);
}

.header {
  display:flex;
  align-items:center;
  gap:10px;
  flex-wrap:wrap;
  margin-bottom:10px;
}

h1 {
  margin:0;
  font-size:28px;
}

.trust {
  display:flex;
  align-items:center;
  gap:8px;
  flex-wrap:wrap;
}

.badge {
  display:inline-flex;
  align-items:center;
  gap:6px;
  font-size:12px;
  font-weight:700;
  padding:4px 10px;
  border-radius:999px;
  border:1px solid rgba(34,197,94,0.45);
  background:rgba(34,197,94,0.12);
  color:rgba(22,101,52,1);
}

.claim-link {
  display:inline-block;
  font-size:14px;
  font-weight:700;
  text-decoration:none;
  padding:8px 12px;
  border-radius:10px;
  border:1px solid #d1d5db;
  background:#fff;
}

.claim-link:hover {
  text-decoration:underline;
}

.card {
  margin-top:18px;
  padding:16px;
  border:1px solid #e6e6e6;
  border-radius:14px;
  background:#fafafa;
}

.row {
  margin-bottom:10px;
  line-height:1.6;
}

.label {
  color:#666;
  font-weight:600;
}

.link {
  color:#0f766e;
  text-decoration:none;
  font-weight:500;
  transition:color .15s ease;
}

.link:hover {
  color:#115e59;
  text-decoration:underline;
}

.website-link {
  overflow-wrap:anywhere;
  word-break:break-word;
}

.description {
  margin-top:16px;
  padding-top:16px;
  border-top:1px solid #e5e7eb;
  color:#374151;
  line-height:1.7;
}

@media (max-width:640px) {

main {
  margin:22px auto;
  padding:0 14px 42px;
}

h1 {
  font-size:24px;
}

}

</style>

</head>

<body>

<main>

<div class="crumbs">

<a href="/">Home</a>

&nbsp;/&nbsp;

<a href="/ma/">Massachusetts</a>

&nbsp;/&nbsp;

<a href={`/ma/${company.townSlug}`}>{townName}</a>

&nbsp;/&nbsp;

<a href={`/ma/${company.townSlug}/${company.serviceId}`}>{serviceName}</a>

&nbsp;/&nbsp;

<span>{company.name}</span>

</div>

<div class="header">

<h1>{company.name}</h1>

<div class="trust">

{isVerified && (
<span class="badge" title="Verified business">✓ Verified</span>
)}

{isClaimed && (
<span class="badge" title="Claimed listing">Claimed</span>
)}

<a
class="claim-link"
href={`/claim?company=${encodeURIComponent(String(company.id ?? Astro.params.company ?? ""))}`}
>
Claim this listing
</a>

</div>

</div>

<div class="card">

<div class="row"><span class="label">Service:</span> {serviceName}</div>

<div class="row"><span class="label">Town:</span> {townName}, MA</div>

{company.phone && (
<div class="row">
<span class="label">Phone:</span>{" "}
<a class="link" href={`tel:${cleanPhone}`}>{company.phone}</a>
</div>
)}

{company.updatedAt && (
<div class="row">
<span class="label">Last updated:</span>{" "}
{new Date(company.updatedAt).toLocaleDateString("en-US", {
year:"numeric",
month:"long",
day:"numeric"
})}
</div>
)}

{company.website && (
<div class="row">
<span class="label">Website:</span>{" "}
<a
class="link website-link"
href={company.website}
target="_blank"
rel="nofollow noopener"
>
{company.website}
</a>
</div>
)}

<div class="row">
📍 <a class="link" href={googleMapsUrl} target="_blank" rel="nofollow noopener">
View on Google Maps
</a>
</div>

{company.description && company.description.trim() && (
<div class="description">
{company.description}
</div>
)}

</div>

</main>

</body>
</html>