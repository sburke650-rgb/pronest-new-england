---
export const prerender = true;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Claim a Listing</title>
  </head>

  <body>
    <main style="max-width: 760px; margin: 40px auto; padding: 0 16px; font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial;">
      <h1 style="margin-bottom: 8px;">Claim a Listing</h1>
      <p style="margin-top: 0; color: #444;">
        If you own a business listed on this site, you can claim your listing and get a Verified badge.
      </p>

      <h2 style="margin-top: 28px;">How to claim</h2>
      <ol style="line-height: 1.6;">
        <li>
          Email us from a business email address (preferred), or include proof you own the business.
        </li>
        <li>
          Include:
          <ul>
            <li>Business name</li>
            <li>Town + service category</li>
            <li>Your phone number</li>
            <li>Link to your website or Google Business Profile</li>
          </ul>
        </li>
        <li>
          We’ll review and mark your listing as <strong>Verified</strong>.
        </li>
      </ol>

      <h2 style="margin-top: 28px;">Fast verification options</h2>
      <ul style="line-height: 1.6;">
        <li>Domain email (name@yourcompany.com)</li>
        <li>Match website ownership (your website lists your phone/address)</li>
        <li>License number (if applicable)</li>
        <li>Video call or phone callback (manual verification)</li>
      </ul>

      <div style="margin-top: 28px; padding: 14px 16px; border: 1px solid #ddd; border-radius: 12px; background: #fafafa;">
        <strong>Claim email:</strong>
        <span> claims@yourdomain.com </span>
        <div style="color:#666; font-size: 14px; margin-top: 6px;">
          (Replace this with your real email address when ready.)
        </div>
      </div>

      <p style="margin-top: 30px;">
        <a href="/" style="text-decoration: none;">← Back to home</a>
      </p>
    </main>
  </body>
</html>
