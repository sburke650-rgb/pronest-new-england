---
import towns from "../data/towns/ma-towns.json";
import services from "../data/services/ma-services.json";

const sorted = [...towns].sort((a, b) => a.name.localeCompare(b.name));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Massachusetts Town Directory</title>
    <meta
      name="description"
      content="Browse Massachusetts towns and explore local service provider pages by town and service."
    />

    <style>
      :root {
        font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      }

      body {
        margin: 0;
        background: #fff;
        color: #111827;
      }

      .wrap {
        max-width: 1100px;
        margin: 0 auto;
        padding: 36px 16px 64px;
      }

      .breadcrumbs {
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 16px;
      }

      .breadcrumbs a {
        color: inherit;
        text-decoration: none;
        border-bottom: 1px solid rgba(0, 0, 0, 0.15);
      }

      .breadcrumbs a:hover {
        border-bottom-color: rgba(0, 0, 0, 0.35);
      }

      .hero {
        margin-bottom: 28px;
      }

      h1 {
        margin: 0 0 12px 0;
        font-size: 36px;
        line-height: 1.1;
        letter-spacing: -0.02em;
      }

      .intro {
        margin: 0;
        max-width: 760px;
        font-size: 17px;
        line-height: 1.7;
        color: #374151;
      }

      .section {
        margin-top: 28px;
        padding: 22px;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        background: #ffffff;
      }

      .section h2 {
        margin: 0 0 14px 0;
        font-size: 24px;
        line-height: 1.2;
      }

      .section p {
        margin: 0 0 16px 0;
        color: #4b5563;
        line-height: 1.6;
      }

      .services-grid {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 10px;
      }

      .services-grid li {
        margin: 0;
      }

      .services-grid a {
        display: block;
        padding: 12px 14px;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        text-decoration: none;
        color: #111827;
        font-weight: 600;
        background: #f9fafb;
      }

      .services-grid a:hover {
        background: #f3f4f6;
      }

      .search-box {
        width: 100%;
        max-width: 440px;
        padding: 12px 14px;
        font-size: 16px;
        border: 1px solid #d1d5db;
        border-radius: 12px;
        background: #fff;
        box-sizing: border-box;
      }

      .results-count {
        margin: 14px 0 0 0;
        color: #6b7280;
        font-size: 15px;
      }

      .town-grid {
        list-style: none;
        margin: 18px 0 0 0;
        padding: 0;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 10px;
      }

      .town-grid li {
        margin: 0;
      }

      .town-grid a {
        display: block;
        padding: 12px 14px;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        text-decoration: none;
        color: #111827;
        font-weight: 600;
        background: #ffffff;
      }

      .town-grid a:hover {
        background: #f9fafb;
      }

      @media (max-width: 640px) {
        .wrap {
          padding: 28px 14px 48px;
        }

        h1 {
          font-size: 30px;
        }

        .section {
          padding: 18px;
        }

        .services-grid,
        .town-grid {
          grid-template-columns: 1fr 1fr;
        }
      }

      @media (max-width: 420px) {
        .services-grid,
        .town-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>

  <body>
    <main class="wrap">
      <div class="breadcrumbs">
        <a href="/">Home</a>
        &nbsp;/&nbsp;
        <span>Massachusetts</span>
      </div>

      <section class="hero">
        <h1>Massachusetts Town Directory</h1>
        <p class="intro">
          Browse Massachusetts towns and explore local service pages by town and
          category. Start with a town search below or browse popular service types.
        </p>
      </section>

      <section class="section">
        <h2>Browse by service</h2>
        <p>Select a service category to explore Massachusetts service pages.</p>

        <ul class="services-grid">
          {services.map((s) => (
            <li>
              <a href={`/ma/services/${s.id}`}>{s.name}</a>
            </li>
          ))}
        </ul>
      </section>

      <section class="section">
        <h2>Find your town</h2>
        <p>Search Massachusetts towns to go directly to local town pages.</p>

        <input
          id="townSearch"
          class="search-box"
          type="text"
          placeholder="Search towns (ex: Boston)"
        />

        <p id="resultsCount" class="results-count"></p>

        <ul id="townList" class="town-grid">
          {sorted.map((town) => (
            <li class="townItem" data-name={town.name.toLowerCase()}>
              <a href={`/ma/${town.slug}`}>{town.name}</a>
            </li>
          ))}
        </ul>
      </section>
    </main>

    <script>
      const input = document.getElementById("townSearch");
      const items = Array.from(document.querySelectorAll(".townItem"));
      const countEl = document.getElementById("resultsCount");

      function updateCount(visible) {
        countEl.textContent =
          visible + " town" + (visible === 1 ? "" : "s") + " shown";
      }

      function filter() {
        const q = (input.value || "").toLowerCase().trim();
        let visible = 0;

        for (const li of items) {
          const name = li.dataset.name || "";
          const show = !q || name.includes(q);
          li.style.display = show ? "" : "none";
          if (show) visible++;
        }

        updateCount(visible);
      }

      input.addEventListener("input", filter);
      updateCount(items.length);
    </script>
  </body>
</html>